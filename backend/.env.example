# ---- Production (Render / Railway / Neon) ----
# A single connection string takes priority when present.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Allowed frontend origin(s), comma-separated. Use your Vercel URL in prod.
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=*

# ---- Local / docker-compose fallback (ignored if DATABASE_URL is set) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=order_management
POSTGRES_HOST=db
POSTGRES_PORT=5432
